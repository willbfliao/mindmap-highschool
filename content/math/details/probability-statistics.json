    "條件機率與貝氏定理": {
      "formulaDetails": [
        {
          "title": "條件機率",
          "latex": "P(A|B) = \\frac{P(A \\cap B)}{P(B)}",
          "symbols": [
            {
              "symbol": "P(A|B)",
              "name": "在 B 已發生下 A 的機率",
              "unit": "無",
              "type": "純量"
            },
            {
              "symbol": "P(A \\cap B)",
              "name": "A 且 B 同時發生的機率",
              "unit": "無",
              "type": "純量"
            },
            {
              "symbol": "P(B)",
              "name": "B 發生的機率",
              "unit": "無",
              "type": "純量"
            }
          ],
          "geometricMeaning": "將樣本空間縮小為 B，在 B 中 A 佔多少比例",
          "examTips": [
            "P(A|B) ≠ P(B|A)，方向不同結果不同",
            "獨立事件：P(A|B) = P(A)，即 B 的發生不影響 A"
          ]
        },
        {
          "title": "貝氏定理",
          "latex": "P(A|B) = \\frac{P(B|A) \\cdot P(A)}{P(B)}",
          "symbols": [
            {
              "symbol": "P(A)",
              "name": "事前機率 (Prior)",
              "unit": "無",
              "type": "純量"
            },
            {
              "symbol": "P(A|B)",
              "name": "事後機率 (Posterior)",
              "unit": "無",
              "type": "純量"
            },
            {
              "symbol": "P(B|A)",
              "name": "似然度 (Likelihood)",
              "unit": "無",
              "type": "純量"
            }
          ],
          "geometricMeaning": "根據新證據（B 已發生）更新對 A 的機率估計",
          "examTips": [
            "常搭配全機率公式展開分母 P(B)",
            "經典題型：疾病檢測的偽陽性問題"
          ]
        }
      ],
      "associations": [
        "垃圾郵件過濾器就是用貝氏定理——根據關鍵字判斷是否為垃圾信",
        "刑事鑑識中 DNA 比對的機率判定也用到條件機率"
      ],
      "examTips": [
        "畫樹狀圖是解條件機率的最清楚方法",
        "貝氏定理的分母用全機率公式展開：P(B) = P(B|A)P(A) + P(B|A')P(A')",
        "獨立事件 P(A∩B) = P(A)·P(B)，不要跟互斥搞混"
      ]
    },

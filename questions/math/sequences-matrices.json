  "questions": [
    {
      "id": "q1",
      "year": 105,
      "text": "等差數列的首項 a₁ = 3，公差 d = 5，則第 20 項 a₂₀ 之值為何？",
      "options": [
        "(A) 95",
        "(B) 98",
        "(C) 100",
        "(D) 103"
      ],
      "answer": "B",
      "explanation": "解析：a₂₀ = a₁ + (20-1)d = 3 + 19×5 = 3 + 95 = 98，故選(B)。",
      "tags": [
        "數列與級數"
      ]
    },
    {
      "id": "q2",
      "year": 106,
      "text": "不等式 |2x - 3| < 5 的解為何？",
      "options": [
        "(A) -1 < x < 4",
        "(B) -4 < x < 1",
        "(C) x < -1 或 x > 4",
        "(D) -1 ≤ x ≤ 4"
      ],
      "answer": "A",
      "explanation": "解析：|2x - 3| < 5 等價於 -5 < 2x - 3 < 5，即 -2 < 2x < 8，-1 < x < 4，故選(A)。",
      "tags": [
        "數與式"
      ]
    },
    {
      "id": "q3",
      "year": 107,
      "text": "等比數列首項 a₁ = 2，公比 r = 3，則前 4 項之和 S₄ 為何？",
      "options": [
        "(A) 40",
        "(B) 60",
        "(C) 80",
        "(D) 120"
      ],
      "answer": "C",
      "explanation": "解析：S₄ = a₁(1-r⁴)/(1-r) = 2(1-81)/(1-3) = 2(-80)/(-2) = 80，故選(C)。",
      "tags": [
        "數列與級數"
      ]
    },
    {
      "id": "q4",
      "year": 108,
      "text": "設矩陣 A = [[2, 1], [3, 4]]，則 det(A) 之值為何？",
      "options": [
        "(A) 3",
        "(B) 5",
        "(C) 8",
        "(D) 11"
      ],
      "answer": "B",
      "explanation": "解析：det(A) = 2×4 - 1×3 = 8 - 3 = 5，故選(B)。",
      "tags": [
        "矩陣"
      ]
    },
    {
      "id": "q5",
      "year": 109,
      "text": "利用克乃美公式解聯立方程式 { 2x + y = 5, x - 3y = -4 }，則 x 之值為何？",
      "options": [
        "(A) 1",
        "(B) 11/7",
        "(C) 2",
        "(D) 19/7"
      ],
      "answer": "B",
      "explanation": "解析：det(A) = 2(-3) - 1(1) = -7。det(Aₓ) = 5(-3) - 1(-4) = -15 + 4 = -11。x = det(Aₓ)/det(A) = -11/(-7) = 11/7，故選(B)。",
      "tags": [
        "矩陣"
      ]
    },
    {
      "id": "q6",
      "year": 111,
      "text": "若 Σ[k=1,n] k = 55，則 n 之值為何？",
      "options": [
        "(A) 9",
        "(B) 10",
        "(C) 11",
        "(D) 12"
      ],
      "answer": "B",
      "explanation": "解析：Σ[k=1,n] k = n(n+1)/2 = 55，n(n+1) = 110，n = 10（因 10×11 = 110），故選(B)。",
      "tags": [
        "數列與級數"
      ]
    },
    {
      "id": "q7",
      "year": 112,
      "text": "多項式 f(x) = x³ - 2x² - 5x + 6，已知 f(1) = 0，則 f(x) 的因式分解為何？",
      "options": [
        "(A) (x - 1)(x - 2)(x + 3)",
        "(B) (x - 1)(x + 2)(x - 3)",
        "(C) (x - 1)(x - 2)(x - 3)",
        "(D) (x + 1)(x - 2)(x + 3)"
      ],
      "answer": "B",
      "explanation": "解析：因 f(1) = 0，(x-1) 為因式。以綜合除法：x³ - 2x² - 5x + 6 ÷ (x-1) = x² - x - 6 = (x+2)(x-3)。故 f(x) = (x-1)(x+2)(x-3)，選(B)。",
      "tags": [
        "數與式"
      ]
    },
    {
      "id": "q8",
      "year": 113,
      "text": "無窮等比級數 1 + 1/3 + 1/9 + 1/27 + ... 的和為何？",
      "options": [
        "(A) 1/2",
        "(B) 3/4",
        "(C) 3/2",
        "(D) 2"
      ],
      "answer": "C",
      "explanation": "解析：首項 a₁ = 1，公比 r = 1/3，|r| < 1 收斂。S = a₁/(1-r) = 1/(1 - 1/3) = 1/(2/3) = 3/2，故選(C)。",
      "tags": [
        "數列與級數"
      ]
    },
    {
      "id": "q9",
      "year": 114,
      "text": "解不等式 x²-5x+6 < 0，解為何？",
      "options": [
        "(A) x<2 或 x>3",
        "(B) 2<x<3",
        "(C) x<-3 或 x>-2",
        "(D) -3<x<-2"
      ],
      "answer": "B",
      "explanation": "解析：x²-5x+6=(x-2)(x-3)<0，兩根 x=2,3，開口向上。在兩根之間為負，即 2<x<3，選(B)。",
      "tags": [
        "數與式"
      ]
    },
    {
      "id": "q10",
      "year": 110,
      "text": "等差數列首項 a₁=50，公差 d=-3，則從第幾項開始為負數？",
      "options": [
        "(A) 第 17 項",
        "(B) 第 18 項",
        "(C) 第 19 項",
        "(D) 第 20 項"
      ],
      "answer": "B",
      "explanation": "解析：aₙ=50+(n-1)(-3)=53-3n<0，n>53/3≈17.67，從第 18 項開始為負，選(B)。",
      "tags": [
        "數列與級數"
      ]
    },
    {
      "id": "q11",
      "year": 114,
      "text": "設 A=[[1,2],[3,4]]，B=[[5,6],[7,8]]，下列哪些正確？",
      "options": [
        "(A) A+B=[[6,8],[10,12]]",
        "(B) det(A)=-2",
        "(C) AB=BA",
        "(D) 2A=[[2,4],[6,8]]",
        "(E) A 有反矩陣"
      ],
      "answer": "ABDE",
      "explanation": "解析：A+B=[[6,8],[10,12]](A)對。det(A)=4-6=-2(B)對。AB=[[19,22],[43,50]]，BA=[[23,34],[31,46]]，AB≠BA(C)錯。2A=[[2,4],[6,8]](D)對。det(A)=-2≠0故可逆(E)對。選(A)(B)(D)(E)。",
      "tags": [
        "矩陣"
      ]
